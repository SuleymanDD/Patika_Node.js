<!DOCTYPE html>
<html lang="tr">

<head>
    <title>EditPost</title>
    <style>
        :root {
            --primary-color: #6366f1;
            --bg-color: #112131;
        }

        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: var(--bg-color);
            padding: 40px;
        }

        .form-container {
            background: white;
            padding: 30px;
            border-radius: 12px;
            justify-content: center;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 700px;
            margin: 50px auto;
        }

        h2 {
            color: #1e293b;
            margin-top: 0;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            font-size: 0.9rem;
            color: #64748b;
            margin-bottom: 8px;
            font-weight: 600;
        }

        input,
        textarea,
        select {
            width: 100%;
            padding: 12px;
            border: 1.5px solid #e2e8f0;
            border-radius: 8px;
            font-size: 1rem;
            transition: border-color 0.3s;
            box-sizing: border-box;
        }

        input:focus,
        textarea:focus,
        select:focus {
            outline: none;
            border-color: var(--primary-color);
            ring: 2px solid #c7d2fe;
        }

        button {
            width: 100%;
            padding: 14px;
            background: var(--primary-color);
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.3s;
            font-size: 1rem;
        }

        button:hover {
            background: #4f46e5;
        }
    </style>
</head>

<body>

    <div class="form-container">
        <h2>İçeriği Düzenle</h2>
        <form action="/posts/<%=post._id.toString()%>?_method=PUT" method="POST">    
            <div class="form-group">
                <label>Başlık</label>
                <input type="text" value="<%=post.title%>" name="title" placeholder="İçerik başlığını girin..." required>
            </div>

            <div class="form-group">
                <label>Açıklama</label>
                <input type="text" value="<%=post.desc%>" name="desc" placeholder="Kısa bir özet..." required>
            </div>

            <div class="form-group">
                <label>Metin</label>
                <textarea name="text" value="" rows="4" placeholder="İçeriği buraya yazın..." required><%=post.text%></textarea>
            </div>

            <div style="display: flex; gap: 15px;">
                <div class="form-group" style="flex: 1;">
                    <label>Yazar</label>
                    <input type="text" value="<%=post.author%>" name="author" placeholder="Adınız" required>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label>Kategori</label>
                    <select name="category" required>
                        <option selected><%=post.category%></option>
                        <% const options = ["Teknoloji", "Yaşam", "Sanat"] %>
                        <% for(let opt of options){ %>
                            <% if (opt !== post.category) { %>
                                <option><%= opt %></option>
                            <% } %>
                        <% } %>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label>Görsel URL</label>
                <input type="url" value="<%=post.image%>" name="image" placeholder="https://resim-adresi.com/foto.jpg">
            </div>

            <button type="submit">İçeriği Gönder</button>
        </form>
    </div>
</body>

</html>