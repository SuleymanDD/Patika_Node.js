<!-- header -->
<header>
   <!-- header inner -->
   <div class="header">
      <div class="container">
         <div class="row">
            <div class="col-xl-3 col-lg-3 col-md-3 col-sm-3 col logo_section">
               <div class="full">
                  <div class="center-desk">
                     <div class="logo">
                        <a href="/"><img src="/images/logo.png" alt="#" /></a>
                     </div>
                  </div>
               </div>
            </div>
            <div class="col-xl-9 col-lg-9 col-md-9 col-sm-9">
               <nav class="navigation navbar navbar-expand-md navbar-dark ">
                  <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarsExample04"
                     aria-controls="navbarsExample04" aria-expanded="false" aria-label="Toggle navigation">
                     <span class="navbar-toggler-icon"></span>
                  </button>
                  <div class="collapse navbar-collapse" id="navbarsExample04">
                     <ul class="navbar-nav mr-auto">
                        <li class="nav-item <%= pageName === 'home' ? 'active' : '' %>">
                           <a class="nav-link" href="/">Home</a>
                        </li>

                        <li class="nav-item <%= pageName === 'about' ? 'active' : '' %>">
                           <a class="nav-link" href="/about">About</a>
                        </li>

                        <li class="nav-item <%= pageName === 'trainer' ? 'active' : '' %>">
                           <a class="nav-link" href="/trainer">Trainer</a>
                        </li>

                        <li class="nav-item <%= pageName === 'gallery' ? 'active' : '' %>">
                           <a class="nav-link" href="/gallery">Gallery</a>
                        </li>

                        <li class="nav-item <%= pageName === 'courses' ? 'active' : '' %>">
                           <a class="nav-link" href="/courses">Courses</a>
                        </li>

                        <li class="nav-item <%= pageName === 'contact' ? 'active' : '' %>">
                           <a class="nav-link" href="/contact">Contact Us</a>
                        </li>
                        <% if(!userId){ %>
                           <li class="nav-item <%= pageName === 'login' ? 'active' : '' %>">
                              <a class="nav-link" href="/login">Log In</a>
                           </li>

                           <li class="nav-item <%= pageName === 'signup' ? 'active' : '' %>">
                              <a class="nav-link" href="/signup">Sign Up</a>
                           </li>
                           <% }else{ %>
                              <li class="nav-item <%= pageName === 'profile' ? 'active' : '' %>">
                                 <a class="nav-link" style=" padding: 7px 0px 24px 0px !important;" href="/profile">
                                    <img src="/icon/avatar_icon.png" alt="Profil" style="width: 30px; height: 30px; border-radius: 50%;">
                                 </a>
                              </li>
                           <% } %>
                     </ul>
                  </div>
               </nav>
            </div>
         </div>
      </div>
   </div>
</header>
<!-- end header inner -->
<!-- end header -->