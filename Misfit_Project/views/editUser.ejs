<%- include('partials/_header') %>

    <style>
        .form-control:focus {
            border-color: #007BFF !important;
            outline: none;
        }

        /* Güvenlik bölümü başlık çizgisi */
        .security-divider {
            border-top: 2px dashed #dee2e6;
        }
    </style>

    <body>
        <%- include('partials/_navbar') %>
            <% if (message.length> 0) { %>
                <p style="display: flex; justify-content: center; background-color: #0a2236; color: #ffffff;">
                    <%= message %>
                </p>
                <% } %>
                    <div class="container mt-5" style="max-width: 500px;">
                        <div class="card shadow-lg border-0 rounded-4 p-4">
                            <div class="card-body p-0">
                                <h4 class="mb-4 fw-bold text-dark">Hesap Bilgilerini Güncelle</h4>

                                <form action="/update/user?_method=PUT" method="POST">

                                    <!-- Ad Soyad (Önce Input, Sonra Label) -->
                                    <div class="form-floating mb-3">
                                        <input type="text" name="name" class="form-control" id="name"
                                            placeholder="Ad Soyad" value="<%= user.name %>" required>
                                        <label for="name" class="text-muted">Ad Soyad</label>
                                    </div>

                                    <!-- Yaş (Önce Input, Sonra Label) -->
                                    <div class="form-floating mb-3">
                                        <input type="number" name="age" class="form-control" id="age" placeholder="Yaş"
                                            value="<%= user.age %>" required>
                                        <label for="age" class="text-muted">Yaşınız</label>
                                    </div>

                                    <!-- Yaşadığınız Şehir (form-select yapıldı, Önce Select, Sonra Label) -->
                                    <div class="form-floating mb-4">
                                        <select name="from" class="form-select" id="from" aria-label="Şehir seçimi"
                                            required>
                                            <option value="<%= user.from %>" disabled selected>
                                                <%= user.from %>
                                            </option>
                                            <option value="İstanbul">İstanbul</option>
                                            <option value="Ankara">Ankara</option>
                                            <option value="İzmir">İzmir</option>
                                            <option value="Diğer">Diğer</option>
                                        </select>
                                        <label for="from" class="text-muted">Yaşadığınız Şehir</label>
                                    </div>

                                    <div class="security-divider my-4"></div>

                                    <!-- Yeni Şifre -->
                                    <div class="form-floating mb-3">
                                        <input type="password" name="newPassword" class="form-control" id="newPassword"
                                            placeholder="Yeni Şifre">
                                        <label for="newPassword" class="text-muted">Yeni Şifre</label>
                                    </div>

                                    <!-- Yeni Şifre Tekrar -->
                                    <div class="form-floating mb-4">
                                        <input type="password" name="confirmPassword" class="form-control"
                                            id="confirmPassword" placeholder="Yeni Şifre (Tekrar)">
                                        <label for="confirmPassword" class="text-muted">Yeni Şifre (Tekrar)</label>
                                    </div>

                                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-semibold">
                                        Bilgileri Kaydet
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <%- include('partials/_footer') %>
    </body>

    </html>