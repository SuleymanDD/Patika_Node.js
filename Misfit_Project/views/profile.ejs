<%- include('partials/_header') %>

    <style>
        /* Hover Efektleri */
        .bg-light-hover:hover {
            background-color: #e9ecef !important;
            transform: translateX(5px);
        }

        .border-danger:hover {
            background-color: #ffe8e8 !important;
            transform: translateX(5px);
        }

        .transition-all {
            transition: all 0.3s ease;
        }

        .transition-all:hover {
            transform: translateY(-8px);
            /* Üzerine gelince hafif yukarı zıplar */
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        }

        .badge {
            font-weight: 500;
            padding: 6px 12px;
        }

        .profile-action-btn {
            transition: all 0.2s ease-in-out;
        }

        .profile-action-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(13, 110, 253, 0.25) !important;
        }
    </style>

    <body>
        <%- include('partials/_navbar') %>

            <div class="container py-5" style="max-width: 1200px;">

                <div class="card border-0 shadow-sm rounded-4 mb-4"
                    style="background: linear-gradient(145deg, #ffffff, #f8f9fa); overflow: hidden;">
                    <div style="height: 6px; background: linear-gradient(90deg, #0d6efd, #0dcaf0);"></div>

                    <div class="card-body p-4">
                        <div class="row align-items-center g-3">
                            <div class="col-auto">
                                <div class="d-flex align-items-center justify-content-center rounded-circle bg-white shadow-sm border border-2 border-primary-subtle"
                                    style="width: 75px; height: 75px; font-size: 32px;">
                                    👤
                                </div>
                            </div>

                            <div class="col">
                                <h3 class="fw-bold text-dark mb-1 m-0" style="letter-spacing: -0.5px;">
                                    <%= user.name %>
                                </h3>
                                <span
                                    class="badge bg-primary bg-opacity-10 text-primary px-3 py-1.5 rounded-pill fw-semibold text-uppercase"
                                    style="font-size: 11px; letter-spacing: 0.5px;">
                                    ⚡ <%= user.role %>
                                </span>
                            </div>

                            <div class="col-12 col-md-auto d-flex align-items-center justify-content-center justify-content-md-start gap-4 mt-3 mt-md-0 border-start-md ps-md-4"
                                style="border-color: #dee2e6 !important;">

                                <div class="d-flex flex-column align-items-center" style="min-width: fit-content;">
                                    <div class="text-muted small text-uppercase fw-bold mb-1"
                                        style="font-size: 10px; letter-spacing: 1px; white-space: nowrap; text-align: center;">
                                        Yaş</div>
                                    <div class="fw-semibold text-dark"
                                        style="font-size: 16px; white-space: nowrap; text-align: center;">
                                        🎂 <%= user.age %>
                                    </div>
                                </div>

                                <div class="d-flex flex-column align-items-center" style="min-width: fit-content;">
                                    <div class="text-muted small text-uppercase fw-bold mb-1"
                                        style="font-size: 10px; letter-spacing: 1px; white-space: nowrap; text-align: center;">
                                        Konum</div>
                                    <div class="fw-semibold text-dark"
                                        style="font-size: 16px; white-space: nowrap; text-align: center;">
                                        📍 <%= user.from %>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>


                <div class="dashboard-container">
                    <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 20px;">
                        <span style="font-size: 24px; font-weight: bold;">Eğitimlerim</span>
                        <% if(courses.length> 0 && userRole==="trainer" ){ %>
                            <a href="/addCourse" class="btn btn-primary"
                                style="display: flex; align-items: center; justify-content: center; height: 40px; width: 80px; margin: 0; padding: 0; font-size: 14px; text-decoration: none; color: white;">
                                Kurs Ekle
                            </a>
                            <% } %>
                    </div>

                    <% if(courses.length){ %>
                        <div class="education-grid">
                            <% for(let i=0; i<courses.length; i++){ %>
                                <div class="education-card">
                                    <img src="<%= courses[i].image %>" alt="Eğitim Görseli">
                                    <div class="card-content">
                                        <h3>
                                            <%= courses[i].title %>
                                        </h3>
                                        <p>
                                            <%= courses[i].shortdesc %>
                                        </p>
                                        <a href="#course"
                                            class="btn btn-primary py-2.5 px-4 rounded-3 fw-semibold shadow-sm d-inline-flex align-items-center gap-2 transition-all profile-action-btn"
                                            onclick="openModal('course-<%= courses[i]._id %>')">
                                            📖 Eğitime Git
                                        </a>
                                    </div>
                                </div>
                                <% } %>
                        </div>
                        <% }else if(userRole==="trainer" ){ %>
                            <div class="text-center py-5">
                                <div class="empty-state-icon"
                                    style="font-size: 50px; color: #ccc; margin-bottom: 15px;">
                                    <i class="fas fa-chalkboard-teacher"></i>
                                </div>
                                <h3 class="text-muted">Henüz hiç kurs oluşturmadınız</h3>
                                <p class="text-muted">Öğrencilerle paylaşmak için ilk kursunuzu oluşturmaya ne dersiniz?
                                </p>
                                <a href="/addCourse" class="btn btn-primary mt-3">Kurs Oluştur</a>
                            </div>
                            <% }else{ %>
                                <div class="text-center py-5"
                                    style="border: 2px dashed #dee2e6; border-radius: 15px; margin: 20px;">
                                    <div style="font-size: 50px; color: #007bff; margin-bottom: 15px;">
                                        <span>📚</span>
                                    </div>
                                    <h3 style="color: #333;">Henüz bir kursa kayıtlı değilsin!</h3>
                                    <p class="text-muted">Öğrenme yolculuğuna başlamak için keşfedilecek harika kurslar
                                        seni
                                        bekliyor.</p>

                                    <a href="/courses" class="btn btn-primary btn-lg mt-3" style="padding: 10px 30px;">
                                        Kursları Keşfet
                                    </a>
                                </div>
                                <% } %>
                </div>

                <div class="d-flex align-items-center my-5">
                    <div
                        style="flex: 1; height: 1px; background: linear-gradient(to right, transparent, #ccc, transparent);">
                    </div>
                    <span class="px-3 text-muted"
                        style="font-size: 0.8rem; letter-spacing: 2px; text-transform: uppercase;">Ayarlar</span>
                    <div
                        style="flex: 1; height: 1px; background: linear-gradient(to left, transparent, #ccc, transparent);">
                    </div>
                </div>

                <div class="dashboard-container">
                    <div class="container mt-4">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <a href="/edit/user"
                                    class="text-decoration-none p-3 rounded-4 d-flex flex-column align-items-center text-center bg-light border h-100 transition-all"
                                    style="transition: all 0.3s ease;">
                                    <div class="p-3 mb-2" style="font-size: 32px;">👤</div>
                                    <span class="fw-semibold text-dark">Bilgileri Düzenle</span>
                                </a>
                            </div>

                            <div class="col-md-4">
                                <a href="/logout"
                                    class="text-decoration-none p-3 rounded-4 d-flex flex-column align-items-center text-center bg-light border h-100 transition-all"
                                    style="transition: all 0.3s ease;">
                                    <div class="p-3 mb-2" style="font-size: 32px;">🚪</div>
                                    <span class="fw-semibold text-dark">Oturumu Kapat</span>
                                </a>
                            </div>

                            <div class="col-md-4">
                                <a href="/delete/user?_method=DELETE"
                                    class="text-decoration-none p-3 rounded-4 d-flex flex-column align-items-center text-center border border-danger border-opacity-25 h-100 transition-all"
                                    style="background-color: #fff5f5; transition: all 0.3s ease;"
                                    onclick="confirm('⚠️ Hesabın silinecek. Emin misin?')">
                                    <div class="p-3 mb-2" style="font-size: 32px;">🗑️</div>
                                    <span class="fw-semibold text-danger">Hesabı Sil</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <% for(let i=0; i<courses.length; i++){ %>
                <div id="course-<%= courses[i]._id %>" class="modal" tabindex="-1"
                    aria-labelledby="modalTitle-<%= courses[i]._id %>" aria-hidden="true">
                    <!-- modal-dialog-scrollable: İçerik taşarsa modal içinde scroll çıksın diye ekledik -->
                    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable"
                        style="max-width: 1000px; width: 100%;">

                        <!-- Sabit yükseklik ve genişlik ayarları burada yapılıyor -->
                        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden"
                            style="height: 1000px; display: flex; flex-direction: column;">

                            <!-- 1. Sabit Başlık Alanı -->
                            <div
                                class="modal-header border-0 pt-4 px-4 pb-2 d-flex align-items-center justify-content-between flex-shrink-0">
                                <h4 class="modal-title fw-bold text-dark mb-0" id="modalTitle-<%= courses[i]._id %>">
                                    <%= courses[i].title %>
                                </h4>
                                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"
                                    aria-label="Kapat" onclick="closeModal('course-<%= courses[i]._id %>')"></button>
                            </div>

                            <!-- 2. Kendi İçinde Kaydırılabilir Gövde Alanı -->
                            <div class="modal-body px-4 pb-3 flex-grow-1" style="overflow-y: auto;">
                                <!-- Kurs Görseli (Görsel boyutu da sabitlendi) -->
                                <div class="mb-4 overflow-hidden rounded-3 shadow-sm">
                                    <img src="<%= courses[i].image %>" alt="<%= courses[i].title %>"
                                        class="img-fluid w-100 object-fit-cover" style="height: 500px;">
                                </div>

                                <!-- Kurs Açıklaması -->
                                <p class="text-muted lh-base text-break" style="font-size: 16px;">
                                    <%= courses[i].description %>
                                </p>
                            </div>

                            <!-- 3. Sabit Buton Alanı -->
                            <div
                                class="modal-header border-0 pt-2 px-4 pb-4 d-flex gap-3 justify-content-end flex-shrink-0">
                                <button type="button"
                                    class="btn btn-primary px-5 py-2.5 rounded-3 fw-semibold shadow-sm"
                                    onclick="window.location.href='/courses/<%= courses[i]._id %>'">
                                    🚀 Derse Başla
                                </button>
                            </div>

                        </div>
                    </div>
                </div>
                <% } %>

                    <%- include('partials/_footer') %>
    </body>

    <script>
        function openModal(modalName) {
            const modal = document.getElementById(modalName);
            modal.style.display = "flex";
        }

        function closeModal(modalName) {
            const modal = document.getElementById(modalName);
            modal.style.display = "none";
        }

        window.onkeydown = function (event) {
            if (event.key === "Escape") {
                const modals = document.querySelectorAll(".modal");
                modals.forEach(modal => {
                    modal.style.display = "none";
                });
            }
        };
    </script>

    </html>