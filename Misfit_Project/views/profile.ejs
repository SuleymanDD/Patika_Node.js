<%- include('partials/_header') %>

    <body>
        <%- include('partials/_navbar') %>

            

            <div class="dashboard-container">
                <h2>Eğitimlerim</h2>
                <div class="education-grid">
                    <div class="education-card">
                        <img src="/images/tra0.jpg" alt="Eğitim Görseli">
                        <div class="card-content">
                            <h3>We22222222222b Geliştirme 10222222221</h3>
                            <p>Modern web teknolojileri hakkında kapsamlı başlangıç eğitimi.</p>
                            <a href="#parentalEducationModal" class="btn"
                                onclick="openModal()">Eğitime
                                Git</a>
                        </div>
                    </div>
                </div>
            </div>

            <div id="parentalEducationModal" class="modal" tabindex="-1" role="dialog" aria-hidden="true">
                <div class="modal-content" id="modalFocusArea" tabindex="0">
                    <h2 id="modalTitle">Eğitim Başlığı</h2>
                    <div class="close-btn"><a href="#" onclick="closeModal()" style="width: 100%; height: 100%;">&times;</a></div>
                    <img id="modalImage" src="/images/tra0.jpg" alt="Eğitim Görseli"
                        style="width:100%; border-radius:8px;">
                    <p id="modalDescription">Eğitim detayı burada görünecek.</p>
                    <button href="#" id="modalLink" class="btn">Derse Başla</button>
                </div>
            </div>

            <%- include('partials/_footer') %>
    </body>

    <script>
        function openModal() {
            const modal = document.getElementById("parentalEducationModal");
            const focusArea = document.getElementById("modalFocusArea");

            // Modalı göster ve body'yi kilitle
            modal.style.display = "flex";
            document.body.classList.add("modal-open");

            // Fokus'u modal içeriğine ver
            focusArea.focus();
        }

        function closeModal() {
            const modal = document.getElementById("parentalEducationModal");
            modal.style.display = "none";
            document.body.classList.remove("modal-open");
        }

        document.addEventListener('keydown', function (e) {
            if (e.key === "Escape") {
                closeModal(); // ESC tuşuna basınca kapat
            }
        });
    </script>

    </html>