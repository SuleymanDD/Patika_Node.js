<%- include("partials/_header") %>

<body class="bg-light">
    <%- include("partials/_navbar") %>
    
    <div class="container my-5" style="max-width: 600px;">
        <!-- Kart yapısı modern soft gölge ve oval köşelerle güncellendi -->
        <div class="card shadow-lg border-0 rounded-4 p-4 bg-white">
            <div class="card-body p-0">
                <h3 class="mb-4 fw-bold text-dark">✍️Kurs İçeriğini Değiştir</h3>

                <form action="/courses/<%= course._id %>?_method=PUT" method="POST">
                    
                    <!-- Kurs Başlığı -->
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" id="title" name="title"
                            placeholder="Örn: İleri Seviye React" value="<%= course.title %>" required>
                        <label for="title" class="text-muted">Kurs Başlığı</label>
                    </div>

                    <!-- Kısa Açıklama -->
                    <div class="form-floating mb-1">
                        <input type="text" class="form-control" id="shortdesc" name="shortdesc"
                            placeholder="Kullanıcıları cezbedecek kısa bir özet" maxlength="150" value="<%= course.shortdesc %>" required>
                        <label for="shortdesc" class="text-muted">Kısa Açıklama</label>
                    </div>
                    <div class="mb-3 px-1">
                        <small class="text-muted" style="font-size: 11px;">💡 En fazla 150 karakter.</small>
                    </div>

                    <!-- Detaylı Açıklama -->
                    <div class="form-floating mb-3">
                        <textarea class="form-control" id="description" name="description" 
                            placeholder="Kursun içeriği hakkında detaylı bilgi verin..." style="height: 130px" required><%= course.description %></textarea>
                        <label for="description" class="text-muted">Detaylı Açıklama</label>
                    </div>

                    <!-- Görsel URL -->
                    <div class="form-floating mb-1">
                        <input type="url" class="form-control" id="image" name="image"
                            placeholder="https://ornek.com/resim.jpg" value="<%= course.image %>" required>
                        <label for="image" class="text-muted">Görsel URL</label>
                    </div>
                    <div class="mb-4 px-1">
                        <small class="text-muted" style="font-size: 11px;">🔗 Görselinizin doğrudan bağlantı adresini girin.</small>
                    </div>

                    <!-- Buton alanı profile uyumlu yapıldı -->
                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-semibold shadow-sm transition-all create-course-btn">
                        🚀 Kursu Kaydet
                    </button>
                </form>
            </div>
        </div>
    </div>

    <%- include("partials/_footer") %>
</body>

<style>
/* Butonun üzerine gelindiğinde modern yukarı esneme efekti */
.create-course-btn {
    transition: all 0.2s ease-in-out;
}
.create-course-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(13, 110, 253, 0.25) !important;
}
/* Textarea içindeki yazının etiketle çakışmaması için küçük bir padding ayarı */
.form-floating > textarea.form-control {
    padding-top: 2rem;
}
</style>

</html>