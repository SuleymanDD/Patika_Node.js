<%- include("partials/_header") -%>
<body style="background-color: #d6f7f0;">
    <%- include("partials/_nav") -%>
<div class="form-container">
                <h2 class="form-title">EDIT THE PROJECT</h2>
                <div class="star-divider">
                    <div class="line"></div>
                    <i class="fas fa-star"></i>
                    <div class="line"></div>
                </div>

                <form action="/posts/<%=post._id.toString()%>?_method=PUT" method="POST" enctype="multipart/form-data">
                    <div class="form-group">
                        <input type="text" name="title" value="<%=post.title%>" id="title" placeholder="Project title" required>
                    </div>

                    <div class="form-group">
                        <textarea name="desc" id="desc" placeholder="Project description" rows="4" required><%=post.desc%></textarea>
                    </div>

                    <div class="form-group file-group">
                        <label for="image" class="file-label">
                            <i class="fas fa-image"></i> Change The Project Image (Click to upload)
                        </label>
                        <input type="file" name="image" id="image" accept="image/*" >
                    </div>

                    <button type="submit" class="btn-send">Change</button>
                </form>
            </div>
<%-include("partials/_footer") -%>