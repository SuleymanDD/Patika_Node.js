<%- include("partials/_header"); -%>

    <body style="background-color: #d6f7f0;">
        <%- include("partials/_nav"); -%>
            <div class="form-container">
                <h2 class="form-title">ADD NEW PROJECT</h2>
                <div class="star-divider">
                    <div class="line"></div>
                    <i class="fas fa-star"></i>
                    <div class="line"></div>
                </div>

                <form action="/posts" method="POST" enctype="multipart/form-data">
                    <div class="form-group">
                        <input type="text" name="title" id="title" placeholder="Project title" required>
                    </div>

                    <div class="form-group">
                        <textarea name="desc" id="desc" placeholder="Project description" rows="4" required></textarea>
                    </div>

                    <div class="form-group file-group">
                        <label for="image" class="file-label">
                            <i class="fas fa-image"></i> Project Image (Click to upload)
                        </label>
                        <input type="file" name="image" id="image" accept="image/*" required>
                    </div>

                    <button type="submit" class="btn-send">Send</button>
                </form>
            </div>
            <%- include("partials/_footer"); -%>
    </body>