<%- include('partials/_header') %>

    <title>Kayıt Ol - Fixtures Furniture</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,400&family=Poppins:wght@300;400;500;600&display=swap"
        rel="stylesheet">

    <!-- FontAwesome Simgeleri -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --primary-color: #A0522D;
            /* Sıcak Toprak / Zengin Ahşap Tonu */
            --primary-hover: #8B4513;
            --accent-color: #D27D2D;
            --bg-light: #F9F7F2;
            /* Fixtures konseptine uygun krem / nötr arka plan */
            --text-dark: #2C2C2C;
            --text-muted: #7A7A7A;
            --border-color: #E2DDD5;
            --card-bg: #FFFFFF;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-color: var(--bg-light);
            color: var(--text-dark);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            font-weight: 700;
            color: var(--text-dark);
            text-decoration: none;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .logo span {
            color: var(--primary-color);
        }

        /* Ana İçerik Konteyneri */
        .main-container {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
            flex-grow: 1;
        }

        .signup-card {
            display: flex;
            width: 100%;
            max-width: 980px;
            background: var(--card-bg);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
            border: 1px solid var(--border-color);
        }

        /* Sol Taraf: Görsel & Slogan Alanı */
        .signup-visual {
            flex: 1;
            background: linear-gradient(135deg, rgba(44, 44, 44, 0.75), rgba(160, 82, 45, 0.85)),
                url('https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?q=80&w=1200&auto=format&fit=crop') center/cover no-repeat;
            padding: 50px 40px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            color: #FFFFFF;
        }

        .visual-content h2 {
            font-family: 'Playfair Display', serif;
            font-size: 34px;
            line-height: 1.3;
            margin-bottom: 15px;
            font-weight: 600;
        }

        .visual-content p {
            font-size: 14px;
            color: #E0E0E0;
            line-height: 1.6;
            font-weight: 300;
        }

        .visual-footer {
            font-size: 13px;
            color: #D0D0D0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .visual-footer i {
            color: #F4A460;
        }

        /* Sağ Taraf: Kayıt Formu */
        .signup-form-container {
            flex: 1.1;
            padding: 50px 45px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .form-header {
            margin-bottom: 28px;
        }

        .form-header h1 {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            color: var(--text-dark);
            margin-bottom: 8px;
            text-align: center;
        }

        .form-header p {
            font-size: 14px;
            color: var(--text-muted);
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: var(--text-dark);
            margin-bottom: 6px;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #660d0d;
            font-size: 15px;
        }

        .form-control {
            width: 100%;
            padding: 12px 14px 12px 42px;
            font-size: 14px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            background-color: #FFFFFF;
            /* Odak kaldırıldığında da arka plan beyaz kalsın */
            color: var(--text-dark);
            /* Yazı renginin görünür kaldığından emin olun */
            transition: all 0.3s ease;
            outline: none;
        }

        .form-control:focus {
            border-color: var(--primary-color);
            background-color: #FFFFFF;
            box-shadow: 0 0 0 3px rgba(160, 82, 45, 0.12);
        }

        .form-row {
            display: flex;
            gap: 15px;
        }

        .form-row .form-group {
            flex: 1;
        }

        /* Şartlar & Koşullar Onayı */
        .checkbox-group {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 22px;
            margin-top: 5px;
        }

        .checkbox-group input[type="checkbox"] {
            accent-color: var(--primary-color);
            margin-top: 3px;
            cursor: pointer;
        }

        .checkbox-group label {
            font-size: 12px;
            color: var(--text-muted);
            line-height: 1.4;
            cursor: pointer;
        }

        .checkbox-group a {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 500;
        }

        .checkbox-group a:hover {
            text-decoration: underline;
        }

        /* Kayıt Butonu */
        .btn-submit {
            width: 100%;
            padding: 14px;
            background-color: var(--primary-color);
            color: #FFFFFF;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.3s ease, transform 0.1s ease;
        }

        .btn-submit:hover {
            background-color: var(--primary-hover);
        }

        .btn-submit:active {
            transform: scale(0.99);
        }

        /* Ayırıcı Çizgi & Sosyal Giriş */
        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 22px 0;
            color: var(--text-muted);
            font-size: 12px;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid var(--border-color);
        }

        .divider span {
            padding: 0 12px;
        }

        .social-login {
            display: flex;
            gap: 12px;
        }

        .btn-social {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            background-color: #FFFFFF;
            font-size: 13px;
            font-weight: 500;
            color: var(--text-dark);
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .btn-social:hover {
            background-color: #F5F3EF;
        }

        .login-prompt {
            text-align: center;
            margin-top: 22px;
            font-size: 13px;
            color: var(--text-muted);
        }

        .login-prompt a {
            color: var(--primary-color);
            font-weight: 600;
            text-decoration: none;
        }

        .login-prompt a:hover {
            text-decoration: underline;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 20px;
            font-size: 12px;
            color: var(--text-muted);
            border-top: 1px solid var(--border-color);
            background-color: #FAF8F5;
        }

        /* Mobil Uyumluluk (Responsive) */
        @media (max-width: 850px) {
            .signup-card {
                flex-direction: column;
            }

            .signup-visual {
                padding: 35px 25px;
                min-height: 200px;
            }

            .signup-form-container {
                padding: 35px 25px;
            }

            .form-row {
                flex-direction: column;
                gap: 0;
            }
        }

        /* Genel Bildirim Kutusu Stili */
        .alert-box {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
            font-weight: 500;
            line-height: 1.4;
            border: 1px solid transparent;
            animation: fadeIn 0.3s ease-in-out;
        }

        .alert-content {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .alert-close {
            background: none;
            border: none;
            font-size: 20px;
            cursor: pointer;
            color: inherit;
            opacity: 0.6;
            transition: opacity 0.2s;
            line-height: 1;
        }

        .alert-close:hover {
            opacity: 1;
        }

        .alert-box.error {
            background-color: #FDF2F2;
            color: #C81E1E;
            border-color: #FDE8E8;
        }

        .alert-box.error .alert-icon::before {
            content: "\f06a";
            /* FontAwesome hata ikonu */
            font-family: "Font Awesome 6 Free";
            font-weight: 900;
        }

        /* Giriş Efekti */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>

    <body>

        <%- include('partials/_navbar') %>

            <!-- Ana İçerik -->
            <main class="main-container">
                <div class="signup-card">

                    <!-- Sol Görsel Alanı -->
                    <div class="signup-visual">
                        <div class="visual-content">
                            <h2>Eviniz İçin En Estetik Dokunuşlar</h2>
                            <p>Fixtures dünyasına katılarak özel mobilya koleksiyonlarımıza, mimari tasarım önerilerine
                                ve üyelere özel fırsatlara anında erişin.</p>
                        </div>
                        <div class="visual-footer">
                            <i class="fa-solid fa-couch"></i>
                            <span>Modern & Minimalist Mobilya Tasarımları</span>
                        </div>
                    </div>

                    <!-- Sağ Form Alanı -->
                    <div class="signup-form-container">
                        <div class="form-header">
                            <h1>Hesap Oluştur</h1>
                            <p>Aşağıdaki bilgileri doldurarak hemen üye olabilirsiniz.</p>
                        </div>

                        <% if (message.length) { %>
                            <div class="alert-box error">
                                <div class="alert-content">
                                    <i class="alert-icon"></i>
                                    <p>
                                        <%= message %>
                                    </p>
                                </div>
                                <button class="alert-close"
                                    onclick="this.parentElement.style.display='none';">&times;</button>
                            </div>
                        <% } %>

                                <form action="/signup" method="POST">

                                    <div class="form-group">
                                        <label for="name">İsim</label>
                                        <div class="input-wrapper">
                                            <i class="fa-regular fa-user"></i>
                                            <input type="text" name="name" id="name" class="form-control"
                                                placeholder="Ahmet" required>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label for="mail">E-posta Adresi</label>
                                        <div class="input-wrapper">
                                            <i class="fa-regular fa-envelope"></i>
                                            <input type="email" id="mail" name="mail" class="form-control"
                                                placeholder="ornek@domain.com" required>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label for="password">Şifre</label>
                                        <div class="input-wrapper">
                                            <i class="fa-solid fa-lock"></i>
                                            <input type="password" id="password" name="password" class="form-control"
                                                placeholder="••••••••" required>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label for="confirm-password">Şifre Tekrarı</label>
                                        <div class="input-wrapper">
                                            <i class="fa-solid fa-shield-halved"></i>
                                            <input type="password" id="confirm-password" name="confirmPassword"
                                                class="form-control" placeholder="••••••••" required>
                                        </div>
                                    </div>

                                    <div class="checkbox-group">
                                        <input type="checkbox" id="terms" name="terms" required>
                                        <label for="terms">
                                            <a href="#">Kullanım Şartları</a> ve <a href="#">Gizlilik Politikası</a>'nı
                                            okudum,
                                            kabul ediyorum.
                                        </label>
                                    </div>

                                    <button type="submit" class="btn-submit">Kayıt Ol</button>
                                </form>

                                <div class="login-prompt">
                                    Zaten bir hesabınız var mı? <a href="/login">Giriş Yap</a>
                                </div>
                    </div>

                </div>
            </main>

            <%- include('partials/_footer') %>

    </body>

    </html>