<%- include('partials/_header') %>
   <style>
      /* --- GENEL KAPSAYICI VE BÖLÜM STİLLERİ --- */

      .page-container {
         max-width: 1000px;
         margin: 0 auto;
         padding: 32px 16px;
         display: flex;
         flex-direction: column;
         gap: 32px;
      }

      /* Eksik Olan Bölüm Bloğu (Section Block) */
      .section-block {
         display: flex;
         flex-direction: column;
         gap: 20px;
         width: 100%;
      }

      .section-title {
         display: flex;
         align-items: center;
         gap: 10px;
      }

      .section-title h2 {
         font-size: 20px;
         font-weight: 700;
         color: #0f172a;
         margin: 0;
      }

      .count-badge {
         background-color: #e2e8f0;
         color: #475569;
         font-size: 12px;
         font-weight: 600;
         padding: 2px 10px;
         border-radius: 12px;
         margin-bottom: 8px;
      }

      /* --- GRID VE KART YAPISI --- */

      .furniture-grid {
         display: grid;
         grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
         gap: 24px;
         width: 100%;
      }

      .furniture-card {
         background: #ffffff;
         border-radius: 12px;
         border: 1px solid #e2e8f0;
         overflow: hidden;
         display: flex;
         flex-direction: column;
         transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .furniture-card:hover {
         transform: translateY(-4px);
         box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.08);
      }

      .card-image {
         position: relative;
         height: 200px;
         width: 100%;
         background-color: #f8fafc;
      }

      .card-image img {
         width: 100%;
         height: 100%;
         object-fit: cover;
         display: block;
      }

      /* Durum Rozetleri */
      .status-tag {
         position: absolute;
         top: 12px;
         right: 12px;
         font-size: 11px;
         font-weight: 600;
         padding: 4px 10px;
         border-radius: 20px;
         backdrop-filter: blur(4px);
         z-index: 2;
      }

      .status-available {
         background-color: rgba(220, 252, 231, 0.95);
         color: #15803d;
      }

      .status-reserved {
         background-color: rgba(254, 226, 226, 0.95);
         color: #b91c1c;
      }

      /* Kart İçeriği */
      .card-body {
         padding: 16px;
         display: flex;
         flex-direction: column;
         gap: 8px;
         flex: 1;
      }

      .category-tag {
         display: inline-block;
         font-size: 11px;
         font-weight: 600;
         color: #4f46e5;
         background-color: #eef2ff;
         padding: 3px 8px;
         border-radius: 6px;
         width: fit-content;
      }

      .card-body h3 {
         font-size: 16px;
         font-weight: 600;
         color: #1e293b;
         margin: 4px 0 0 0;
      }

      .created-date {
         font-size: 12px;
         color: #64748b;
         display: flex;
         align-items: center;
         gap: 6px;
         margin-top: 4px;
      }

      /* Alt Kısım (Fiyat ve Buton) */
      .card-footer {
         display: flex;
         align-items: center;
         justify-content: space-between;
         margin-top: auto;
         padding-top: 12px;
         border-top: 1px solid #f1f5f9;
      }

      .price {
         font-size: 17px;
         font-weight: 700;
         color: #0f172a;
      }

      /* Buton Stilleri */
      .btn {
         display: inline-flex;
         align-items: center;
         justify-content: center;
         gap: 8px;
         padding: 8px 16px;
         border-radius: 8px;
         font-size: 13px;
         font-weight: 500;
         cursor: pointer;
         border: none;
         transition: all 0.2s ease;
      }

      .btn-primary {
         background-color: #4f46e5;
         color: #ffffff;
      }

      .btn-primary:hover {
         background-color: #4338ca;
      }

      .btn-disabled {
         background-color: #f1f5f9;
         color: #94a3b8;
         cursor: not-allowed;
         border: 1px solid #e2e8f0;
      }
   </style>

   <body>
