<div class="header_section">
   <div class="container">
      <nav class="navbar navbar-expand-lg navbar-light bg-light">
         <a class="navbar-brand" href="/"><img src="/images/logo.png"></a>
         <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent"
            aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
         </button>
         <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav ml-auto">
               <li class="nav-item <%= pageName === 'home' ? 'active' : '' %>">
                  <a class="nav-link" href="/">Home</a>
               </li>
               <li class="nav-item <%= pageName === 'about' ? 'active' : '' %>">
                  <a class="nav-link" href="/about">About</a>
               </li>
               <li class="nav-item <%= pageName === 'furnitures' ? 'active' : '' %>">
                  <a class="nav-link" href="/furnitures">Furnitures</a>
               </li>
               <li class="nav-item <%= pageName === 'contact' ? 'active' : '' %>">
                  <a class="nav-link" href="/contact">Contact Us</a>
               </li>
               <% if(userID){ %>
                  <li class="nav-item <%= pageName === 'profile' ? 'active' : '' %>">
                     <div class="profile-container">
                        <!-- Tıklanabilir Profil Butonu -->
                        <button type="button" id="profileBtn" class="profile-btn" aria-label="Profil Menüsü" onclick="window.location.href='/profile'">
                           <!-- SVG Profil İkonu (Kullanıcı Resmi Yoksa) -->
                           <svg class="profile-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                              stroke-linejoin="round">
                              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                              <circle cx="12" cy="7" r="4"></circle>
                           </svg>
                        </button>
                     </div>
                  </li>
               <% }else{ %>
                     <li class="nav-item <%= pageName === 'login' ? 'active' : '' %>">
                        <a class="nav-link" href="/login">Login</a>
                     </li>
                     <li class="nav-item <%= pageName === 'signup' ? 'active' : '' %>">
                        <a class="nav-link" href="/signup">Signup</a>
                     </li>
               <% } %>
            </ul>
            <form class="form-inline my-2 my-lg-0">
               <div class="call_text">
                  <ul>
                     <li><a href="#"><i class="fa fa-phone" aria-hidden="true"></i><span class="padding_left_15">Call :
                              +01 1234567890</span></a></li>
                     <li><a href="#"><i class="fa fa-map-marker" aria-hidden="true"></i><span
                              class="padding_left_15">Loram ipusm</span></a></li>
                  </ul>
               </div>
            </form>
         </div>
      </nav>
      <div class="custome_menu">
         <ul>
            <li class="<%= pageName === 'home' ? 'active' : '' %>"><a href="/">Home</a></li>
            <li class="<%= pageName === 'about' ? 'active' : '' %>"><a href="/about">About</a></li>
            <li class="<%= pageName === 'furnitures' ? 'active' : '' %>"><a href="/furnitures">Furnitures</a></li>
            <li class="<%= pageName === 'contact' ? 'active' : '' %>"><a href="/contact">Contact Us</a></li>
            <% if(userID){ %>
               <li class="<%= pageName === 'profile' ? 'active' : '' %>">
                  <div class="profile-container">
                     <!-- Tıklanabilir Profil Butonu -->
                     <button type="button" id="profileBtn" class="profile-btn" aria-label="Profil Menüsü" onclick="window.location.href='/profile'">
                        <!-- SVG Profil İkonu (Kullanıcı Resmi Yoksa) -->
                        <svg class="profile-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                           viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                           stroke-linejoin="round">
                           <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                           <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                     </button>
                  </div>
               </li>
            <% }else{ %>
                  <li class="<%= pageName === 'login' ? 'active' : '' %>"><a href="/login">Login</a></li>
                  <li class="<%= pageName === 'signup' ? 'active' : '' %>"><a href="/signup">Signup</a></li>
            <% } %>
            <li><a href="#"><i class="fa fa-search" aria-hidden="true"></i></a></li>
         </ul>
      </div>
   </div>
</div>
<!-- header section end -->